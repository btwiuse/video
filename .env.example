# DeepSeek API
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat           # V3, fast (recommended for storyboard)
DEEPSEEK_REASONING_MODEL=deepseek-reasoner  # R1, slower but deeper
DEEPSEEK_TIMEOUT=600                   # API timeout in seconds
DEEPSEEK_USE_REASONING=false           # Set to true for complex scripts

# Image generation provider
# Options: flux, flux-ultra, sdxl, seedream, stepfun, comfyui, null
IMAGE_PROVIDER=flux
IMAGE_API_KEY=your-key-here              # Replicate token, Ark API key, or StepFun API key
COMFYUI_URL=http://localhost:8188
STEPFUN_MODEL=step-image-edit-2           # step-image-edit-2, step-2x-large, step-1x-medium

# Video generation provider
# Options: tokenvoke (recommended), seedance (direct Ark API), null
VIDEO_PROVIDER=tokenvoke
VIDEO_API_KEY=your-video-key-here              # TokenVoke API key (or Ark key for seedance)

# Model name (shared across providers)
VIDEO_MODEL=doubao-seedance-2-0-fast-260128

# TokenVoke Seedance settings (when VIDEO_PROVIDER=tokenvoke)
TOKENVOKE_BASE_URL=https://overseas.tokenvoke.com
TOKENVOKE_MAX_DURATION_SEC=15
TOKENVOKE_MAX_IMAGES=9

# Audio generation (dialogue / TTS)
# Options: elevenlabs, null
AUDIO_PROVIDER=null
AUDIO_API_KEY=your-key-here              # ElevenLabs API key (when AUDIO_PROVIDER=elevenlabs)

# Pipeline settings
OUTPUT_DIR=./output
