# DeepSeek API
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat           # V3, fast (recommended for storyboard)
DEEPSEEK_REASONING_MODEL=deepseek-reasoner  # R1, slower but deeper
DEEPSEEK_TIMEOUT=600                   # API timeout in seconds
DEEPSEEK_USE_REASONING=false           # Set to true for complex scripts

# Image generation provider
# Options: flux, flux-ultra, sdxl, seedream, comfyui, null
IMAGE_PROVIDER=flux
IMAGE_API_KEY=your-key-here              # Replicate token or Ark API key
COMFYUI_URL=http://localhost:8188

# Video generation provider
# Options: seedance, null
VIDEO_PROVIDER=seedance
VIDEO_API_KEY=your-video-key-here          # Video API key (e.g. Ark key for Seedance)

# Seedance 2.0 settings (when VIDEO_PROVIDER=seedance)
SEEDANCE_MODEL=doubao-seedance-2-0-260128

# Audio generation (dialogue / TTS)
# Options: elevenlabs, null
AUDIO_PROVIDER=null
AUDIO_API_KEY=your-key-here              # ElevenLabs API key (when AUDIO_PROVIDER=elevenlabs)

# Pipeline settings
OUTPUT_DIR=./output
